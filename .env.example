# OpenClaw Agent
OPENCLAW_GATEWAY_TOKEN=<generate: openssl rand -hex 32>
OPENCLAW_PORT=18789

# LiteLLM
LITELLM_MASTER_KEY=<generate: openssl rand -hex 24>
LLAMA_SERVER_URL=http://host.docker.internal:18080/v1
REASONER_LOCAL_MODEL=openai/Qwen3.5-27B-IQ3_M

# Judge model
JUDGE_LOCAL_MODEL=openai/Qwen3.5-27B-IQ3_M

# Judge portable — direct fallback, skips LiteLLM
PORTABLE_SERVER_URL=<portable llama-server URL, e.g. https://host:port/v1>
JUDGE_PORTABLE_MODEL=Qwen2.5-7B-Instruct-Q4_K_M

# Inbound injection filter (tool result prompt injection detection)
INBOUND_ENABLED=true
INBOUND_JUDGE_MODE=signal+judge   # signal+judge | signal-only
INBOUND_MIN_CHARS=30              # tool results shorter than this skip Judge LLM
INBOUND_CACHE_TTL=600             # dedup cache TTL in seconds (0 = no caching)
INBOUND_CACHE_MAX=1024            # max dedup cache entries

# Web search (Brave Search API)
BRAVE_API_KEY=<Brave Search API key>

# LiteLLM debug port (localhost only)
LITELLM_PORT=4100
