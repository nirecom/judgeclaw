{
  "gateway": {
    "bind": "lan",
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowedOrigins": [
        "https://paw.nire.to"
      ]
    }
  },
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://openclaw-bridge:8080/v1",
        "apiKey": "not-needed",
        "api": "openai-responses",
        "models": [
          {
            "id": "agent-reasoner",
            "name": "Qwen3.5-27B (via llama-swap)"
          }
        ]
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "BRAVE_API_KEY"
        }
      }
    },
    "profile": "minimal",
    "alsoAllow": [
      "web_search",
      "web_fetch",
      "exec"
    ]
  },
  "meta": {
    "lastTouchedVersion": "2026.4.2",
    "lastTouchedAt": "2026-04-05T03:52:59.026Z"
  },
  "agents": {
    "defaults": {
      "contextTokens": 28000,
      "compaction": {
        "mode": "default"
      }
    }
  }
}